# Required: RAPTOR + the QA model both call OpenAI.
OPENAI_API_KEY=sk-...

# Required for spend tracking + caps. Without Mongo, the API refuses builds.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=raptor_viz

# CORS origin for the Angular dev server.
FRONTEND_ORIGIN=http://localhost:4200

# Spend caps (USD). Override per environment.
DAILY_USD_CAP=1.0
PER_IP_USD_CAP=0.1
SAFETY_MARGIN=0.9
OPENAI_MAX_CONCURRENCY=8
MAX_INPUT_CHARS=20000
